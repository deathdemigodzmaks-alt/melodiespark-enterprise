{
  "name": "melodiespark-enterprise",
  "version": "1.0.0",
  "description": "Enterprise SaaS Platform - MelodieSpark",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:push": "cd packages/database && pnpm prisma db push",
    "db:migrate": "cd packages/database && pnpm prisma migrate dev",
    "db:generate": "cd packages/database && pnpm prisma generate",
    "deploy:cloud": "bash .saas-deployment/scripts/deploy-cloud.sh",
    "deploy:vps": "bash .saas-deployment/scripts/deploy-vps.sh",
    "deploy:k8s": "kubectl apply -f k8s/deployment.yaml",
    "deploy:aws": "cd terraform && terraform apply",
    "monitor": "bash .saas-deployment/scripts/monitor.sh",
    "backup": "bash .saas-deployment/scripts/backup.sh",
    "restore": "bash .saas-deployment/scripts/restore.sh"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "next": "^14.0.4",
    "fastify": "^4.25.2",
    "@fastify/cors": "^8.5.0",
    "@fastify/jwt": "^7.2.4",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "axios": "^1.6.5",
    "zustand": "^4.4.7",
    "lucide-react": "^0.309.0",
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.16",
    "@prisma/client": "^5.8.0",
    "prisma": "^5.8.0",
    "redis": "^4.6.12",
    "ioredis": "^5.3.2",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4",
    "better-auth": "latest",
    "litellm": "^1.0.0",
    "@anthropic-ai/sdk": "^0.20.0",
    "openai": "^4.40.0",
    "stripe": "^14.15.0",
    "nodemailer": "^6.9.7",
    "jsonwebtoken": "^9.1.2",
    "bcryptjs": "^2.4.3",
    "date-fns": "^2.30.0",
    "lodash": "^4.17.21",
    "uuid": "^9.0.1",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "p-queue": "^7.4.1",
    "bull": "^4.12.2",
    "ioredis-mock": "^5.8.3",
    "joi": "^17.12.0",
    "validator": "^13.11.0",
    "sharp": "^0.33.0",
    "multer": "^1.4.5",
    "aws-sdk": "^2.1555.0",
    "@aws-sdk/client-s3": "^3.535.0",
    "googleapis": "^118.0.0",
    "discord.js": "^14.14.1",
    "slack-sdk": "^6.9.0",
    "telegram": "^2.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "typescript": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "eslint-config-next": "^14.0.4",
    "prettier": "^3.1.0",
    "turbo": "^1.10.16",
    "vitest": "^1.1.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/jest-dom": "^6.1.5",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^7.3.0",
    "supertest": "^6.3.3",
    "@types/supertest": "^6.0.2",
    "docker-compose": "^0.24.8",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.12.0"
}
