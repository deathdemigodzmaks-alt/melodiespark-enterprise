{% assign current_variant = product.selected_or_first_available_variant %}
{% assign featured_image = current_variant.featured_image | default: product.featured_image %}

<div class="product-container" data-product-id="{{ product.id }}">
  <div class="product-gallery">
    <div class="featured-image">
      {% if featured_image %}
        {{
          featured_image
          | image_url: width: 800
          | image_tag: loading: 'eager', class: 'featured-product-image'
        }}
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>
    
    {% if product.media.size > 1 %}
      <div class="product-thumbnails">
        {% for media in product.media %}
          <div class="thumbnail {% if media.id == featured_image.id %}active{% endif %}">
            {{
              media
              | image_url: width: 100
              | image_tag: loading: 'lazy'
            }}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
  
  <div class="product-info">
    <h1 class="product-title">{{ product.title }}</h1>
    
    <div class="product-price">
      <span class="price" data-price="{{ current_variant.price }}">
        {{ current_variant.price | money }}
      </span>
      
      {% if current_variant.compare_at_price > current_variant.price %}
        <span class="compare-price">
          {{ current_variant.compare_at_price | money }}
        </span>
        <span class="sale-badge">{{ 'products.product.on_sale' | t }}</span>
      {% endif %}
    </div>
    
    <!-- Crypto Price Display -->
    {% if settings.enable_crypto_prices %}
      <div class="crypto-price" data-fiat-price="{{ current_variant.price | money_without_currency }}">
        <span class="btc-price">Loading BTC price...</span>
        <span class="eth-price">Loading ETH price...</span>
      </div>
    {% endif %}
    
    <div class="product-description rte">
      {{ product.description }}
    </div>
    
    {% if product.has_variants %}
      <div class="variant-selector">
        <label for="variant-select">{{ 'products.product.variant' | t }}</label>
        <select id="variant-select" name="id">
          {% for variant in product.variants %}
            <option
              value="{{ variant.id }}"
              {% if variant == current_variant %}selected{% endif %}
              {% unless variant.available %}disabled{% endunless %}
              data-price="{{ variant.price }}"
              data-compare-price="{{ variant.compare_at_price }}"
            >
              {{ variant.title }}
              {% if variant.available == false %}
                - {{ 'products.product.sold_out' | t }}
              {% endif %}
            </option>
          {% endfor %}
        </select>
      </div>
    {% endif %}
    
    <div class="quantity-selector">
      <label for="quantity">{{ 'products.product.quantity' | t }}</label>
      <input
        type="number"
        id="quantity"
        name="quantity"
        value="1"
        min="1"
        max="{{ current_variant.inventory_quantity }}"
      >
    </div>
    
    <!-- Add to Cart Form with Real Payment Options -->
    {% form 'product', product, id: 'product-form' %}
      <input type="hidden" name="id" value="{{ current_variant.id }}">
      
      <div class="add-to-cart-actions">
        <button
          type="submit"
          name="add"
          class="add-to-cart-button {% unless current_variant.available %}disabled{% endunless %}"
          {% unless current_variant.available %}disabled{% endunless %}
        >
          {% if current_variant.available %}
            {{ 'products.product.add_to_cart' | t }}
          {% else %}
            {{ 'products.product.sold_out' | t }}
          {% endif %}
        </button>
        
        <!-- Buy Now with Stripe -->
        {% if settings.enable_stripe_checkout %}
          <button
            type="button"
            class="buy-now-button stripe-checkout"
            data-product-id="{{ product.id }}"
            data-variant-id="{{ current_variant.id }}"
            {% unless current_variant.available %}disabled{% endunless %}
          >
            Buy Now
          </button>
        {% endif %}
        
        <!-- Crypto Checkout -->
        {% if settings.enable_crypto_checkout %}
          <button
            type="button"
            class="crypto-checkout-button"
            data-product-id="{{ product.id }}"
            data-variant-id="{{ current_variant.id }}"
            {% unless current_variant.available %}disabled{% endunless %}
          >
            <span class="crypto-icon">₿</span> Pay with Crypto
          </button>
        {% endif %}
      </div>
    {% endform %}
    
    <!-- Product Meta -->
    <div class="product-meta">
      <div class="sku">
        <span>{{ 'products.product.sku' | t }}:</span>
        <span>{{ current_variant.sku }}</span>
      </div>
      
      <div class="inventory">
        <span>{{ 'products.product.availability' | t }}:</span>
        <span>
          {% if current_variant.inventory_management %}
            {% if current_variant.inventory_quantity > 0 %}
              {{ current_variant.inventory_quantity }} {{ 'products.product.in_stock' | t }}
            {% else %}
              {{ 'products.product.out_of_stock' | t }}
            {% endif %}
          {% else %}
            {{ 'products.product.in_stock' | t }}
          {% endif %}
        </span>
      </div>
    </div>
    
    <!-- Karma Points Reward -->
    {% if settings.enable_karma_rewards %}
      <div class="karma-reward">
        <span class="karma-icon">✨</span>
        Earn {{ current_variant.price | times: settings.karma_multiplier | floor }} Karma Points
      </div>
    {% endif %}
  </div>
</div>

<!-- Stripe Payment Element Container (hidden by default) -->
<div id="stripe-payment-modal" class="payment-modal hidden">
  <div class="modal-content">
    <button class="close-modal">&times;</button>
    <h2>Complete Payment</h2>
    <div id="stripe-card-element"></div>
    <button id="stripe-submit-button">Pay {{ current_variant.price | money }}</button>
    <div id="payment-error" class="error-message"></div>
  </div>
</div>

<script type="application/json" id="ProductJson-{{ product.id }}">
  {{ product | json }}
</script>
